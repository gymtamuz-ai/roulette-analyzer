# ─── Railway / Render: use DATABASE_URL (provided automatically by the platform)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Local development (individual vars) ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=roulette_analyzer
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Optional: restrict CORS to your Vercel domain ───────────────────────────
# FRONTEND_URL=https://your-app.vercel.app
